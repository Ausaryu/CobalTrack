# Clé secrète pour la signature des JWT — obligatoire en production
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Chemin de la base de données SQLite (relatif au dossier backend/)
DATABASE_URL=sqlite:///./cobaltrack.db

# Origines autorisées par CORS, séparées par des virgules, sans espaces
# Le wildcard * est explicitement refusé
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pour accès depuis une autre machine du réseau local (remplacer IP_DE_LA_MACHINE) :
# BACKEND_CORS_ORIGINS=http://IP_DE_LA_MACHINE:5173,http://localhost:5173
